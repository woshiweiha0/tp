@startuml
!pragma layout smetana

title Delete Record Sequence Diagram

actor User
participant Resumake
participant Parser
participant DeleteCommand
participant RecordList
participant User as UserSingleton
participant Storage

User -> Resumake: delete INDEX
Resumake -> Parser: parse(input, ui)
Parser --> Resumake: DeleteCommand (record mode)
Resumake -> DeleteCommand: execute(list)
DeleteCommand -> RecordList: removeIndex(index-1)
RecordList -> UserSingleton: removeSkills(record.tech)
Resumake -> Storage: saveToFile(list)
Storage -> Storage: serialize + compare + write if changed
@enduml
