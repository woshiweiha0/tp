@startuml
!pragma layout smetana

title FindBullet Command Sequence Diagram

actor User
participant Resumake
participant Parser
participant FindBulletCommand
participant RecordList
participant Record
participant Ui
participant Storage

User -> Resumake: findbullet KEYWORD
Resumake -> Parser: parse(input, ui)
Parser --> Resumake: FindBulletCommand
Resumake -> FindBulletCommand: execute(list)
loop for each record
  FindBulletCommand -> Record: getBullets()
  FindBulletCommand -> Ui: print matching bullets (if any)
end
Resumake -> Storage: saveToFile(list)
Storage -> Storage: serialize + compare + skip if unchanged
@enduml
